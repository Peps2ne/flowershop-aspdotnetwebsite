@model FlowerShopApp.Models.Product

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ürünü Düzenle";
}

<div class="card border-0 shadow-sm rounded-4 p-4" style="max-width: 700px;">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase text-muted mb-1">Ürün Adı</label>
                <input asp-for="Name" class="form-control rounded-3 p-3" required />
            </div>
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase text-muted mb-1">URL Slug</label>
                <input asp-for="Slug" class="form-control rounded-3 p-3" />
            </div>
            <div class="col-12">
                <label class="fw-bold small text-uppercase text-muted mb-1">Açıklama</label>
                <textarea asp-for="Description" class="form-control rounded-3 p-3" rows="3"></textarea>
            </div>
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase text-muted mb-1">Fiyat (₺)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control rounded-3 p-3" required />
            </div>
            <div class="col-md-3">
                <label class="fw-bold small text-uppercase text-muted mb-1">Stok</label>
                <input asp-for="Stock" type="number" class="form-control rounded-3 p-3" required />
            </div>
            <div class="col-md-3">
                <label class="fw-bold small text-uppercase text-muted mb-1">Kategori</label>
                <select asp-for="CategoryId" class="form-select rounded-3 p-3" asp-items="ViewBag.Categories" required>
                    <option value="">- Seçiniz -</option>
                </select>
            </div>
            <div class="col-12">
                <label class="fw-bold small text-uppercase text-muted mb-1">Resim URL</label>
                <input asp-for="ImageUrl" class="form-control rounded-3 p-3" placeholder="https://..." />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.ImageUrl" class="rounded-3" style="height: 100px; object-fit: cover;" onerror="this.style.display='none'" />
                    </div>
                }
            </div>
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase text-muted mb-1">Rozet Metni</label>
                <input asp-for="Badge" class="form-control rounded-3 p-3" placeholder="Çok Satan, Yeni, Fırsat..." />
            </div>
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase text-muted mb-1">Rozet Rengi (Bootstrap)</label>
                <select asp-for="BadgeColor" class="form-select rounded-3 p-3">
                    <option value="">- Yok -</option>
                    <option value="danger">Kırmızı (danger)</option>
                    <option value="success">Yeşil (success)</option>
                    <option value="warning text-dark">Sarı (warning)</option>
                    <option value="info">Mavi (info)</option>
                    <option value="primary">Koyu Mavi (primary)</option>
                </select>
            </div>
            <div class="col-12 d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-accent rounded-pill px-5 py-3 fw-bold shadow-sm">
                    <i class="fa-solid fa-check-double me-2"></i> Güncelle ve Kaydet
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-3 fw-bold">İptal</a>
            </div>
        </div>
    </form>
</div>
