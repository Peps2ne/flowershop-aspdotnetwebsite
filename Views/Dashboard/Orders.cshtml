@model IEnumerable<FlowerShopApp.Models.Order>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-0" style="color: #3D2C33;">Sipariş Takibi</h2>
        <span class="badge rounded-pill px-3 py-2" style="background-color: #FFF8F5; color: #D4728A; border: 1px solid #F5E8EA;">
            Toplam @Model.Count() Sipariş
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-panel p-5 text-center bg-white">
            <div class="mb-4">
                <i class="fa-solid fa-box-open fa-4x" style="color: #F5E8EA;"></i>
            </div>
            <h4 class="fw-bold">Henüz siparişiniz bulunmuyor.</h4>
            <p class="text-muted">Bahçemizdeki taze çiçeklerden ilk siparişinizi vermek ister misiniz?</p>
            <a asp-controller="Home" asp-action="Products" class="btn btn-accent rounded-pill px-5 py-3 mt-3 fw-bold">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var order in Model)
            {
                <div class="card-soft p-0 overflow-hidden border-0 bg-white hover-lift">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-2 p-4 text-center border-end" style="background-color: #FFF8F5;">
                            <span class="d-block text-muted small text-uppercase mb-1">Sipariş No</span>
                            <span class="fw-bold fs-5" style="color: #3D2C33;">#SPR-@order.Id</span>
                        </div>
                        <div class="col-md-3 p-4">
                            <span class="d-block text-muted small text-uppercase mb-1">Tarih</span>
                            <span class="fw-bold">@order.OrderDate.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="col-md-2 p-4">
                            <span class="d-block text-muted small text-uppercase mb-1">Toplam</span>
                            <span class="fw-bold text-accent">@order.TotalAmount.ToString("0.00") ₺</span>
                        </div>
                        <div class="col-md-2 p-4">
                            @{
                                var statusClass = order.Status switch
                                {
                                    OrderStatus.Pending => "bg-warning text-dark",
                                    OrderStatus.Shipped => "bg-info text-white",
                                    OrderStatus.Delivered => "bg-success text-white",
                                    _ => "bg-secondary text-white"
                                };
                                var statusText = order.Status switch
                                {
                                    OrderStatus.Pending => "Hazırlanıyor",
                                    OrderStatus.Shipped => "Yolda",
                                    OrderStatus.Delivered => "Teslim Edildi",
                                    _ => "İptal Edildi"
                                };
                            }
                            <span class="badge @statusClass rounded-pill px-3 py-2">@statusText</span>
                        </div>
                        <div class="col-md-3 p-4 text-end">
                            <a asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-outline-accent rounded-pill px-4 fw-bold">
                                Detayları Gör <i class="fa-solid fa-chevron-right ms-2 small"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
