@model FlowerShopApp.Models.Order
@{
    ViewData["Title"] = "Sipariş Detayı";
    
    var statusSteps = new[] {
        new { Name = "Hazırlanıyor", Icon = "fa-box-open", Active = Model.Status >= OrderStatus.Pending, Color = "#D4728A" },
        new { Name = "Kargoya Verildi", Icon = "fa-truck-fast", Active = Model.Status >= OrderStatus.Shipped, Color = "#81B29A" },
        new { Name = "Teslim Edildi", Icon = "fa-house-circle-check", Active = Model.Status >= OrderStatus.Delivered, Color = "#F2CC8F" }
    };

    int currentStep = Model.Status switch {
        OrderStatus.Pending => 0,
        OrderStatus.Shipped => 1,
        OrderStatus.Delivered => 2,
        _ => 0
    };
}

<div class="container py-5" style="max-width: 1100px;">
    <!-- Header Area -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2" style="font-size: 0.9rem;">
                    <li class="breadcrumb-item"><a asp-action="Orders" class="text-accent text-decoration-none fw-bold">Siparişlerim</a></li>
                    <li class="breadcrumb-item active text-muted">#SPR-@Model.Id</li>
                </ol>
            </nav>
            <h1 class="fw-extrabold mb-0" style="color: #3D2C33; font-size: 2.2rem;">Sipariş Detayı</h1>
        </div>
        <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex align-items-center gap-3">
            <div class="p-2 rounded-3 bg-soft-accent d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-calendar-day text-accent fs-4"></i>
            </div>
            <div>
                <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">Sipariş Tarihi</small>
                <span class="fw-bold" style="color: #3D2C33;">@Model.OrderDate.ToString("dd MMMM yyyy, HH:mm")</span>
            </div>
        </div>
    </div>

    <!-- Modern Stepper -->
    <div class="card-soft border-0 mb-5 p-5 bg-white position-relative overflow-hidden">
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: radial-gradient(circle at 10% 20%, rgba(212, 114, 138, 0.03) 0%, transparent 50%);"></div>
        
        <div class="row position-relative" style="z-index: 1;">
            @for (int i = 0; i < statusSteps.Length; i++)
            {
                var step = statusSteps[i];
                bool isPast = i < currentStep;
                bool isCurrent = i == currentStep;
                
                <div class="col text-center">
                    <div class="d-inline-flex flex-column align-items-center">
                        <div class="step-circle mb-3 @(step.Active ? "active" : "") @(isCurrent ? "pulse" : "")" 
                             style="width: 70px; height: 70px; border-radius: 20px; display: flex; align-items: center; justify-content: center; 
                                    background: @(step.Active ? step.Color : "#F8F9FA"); color: @(step.Active ? "white" : "#ADB5BD"); 
                                    box-shadow: @(step.Active ? "0 10px 20px -5px " + step.Color + "66" : "none");">
                            <i class="fa-solid @step.Icon fs-3"></i>
                        </div>
                        <h6 class="fw-bold mb-1 @(step.Active ? "text-dark" : "text-muted")" style="font-size: 0.95rem;">@step.Name</h6>
                        @if(isCurrent) { <span class="badge rounded-pill bg-light text-dark border small fw-bold">Şu Anki Durum</span> }
                    </div>
                    
                    @if (i < statusSteps.Length - 1)
                    {
                        <div class="d-none d-md-block position-absolute start-50 translate-middle-x" style="width: 50%; top: 35px; left: 100%; height: 3px; background: #F1F3F5; z-index: -1;">
                            <div class="h-100 transition-all" style="width: @(isPast ? "100%" : isCurrent ? "50%" : "0%"); background: #D4728A;"></div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Products List -->
        <div class="col-lg-7">
            <div class="card-soft border-0 bg-white h-100 p-0 overflow-hidden shadow-hover">
                <div class="p-4 bg-light border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0" style="color: #3D2C33;"><i class="fa-solid fa-spa text-accent me-2"></i>Siparişteki Ürünler</h5>
                    <span class="badge bg-white text-dark border rounded-pill px-3 py-2 fw-bold">@Model.Items.Count Ürün</span>
                </div>
                <div class="p-0">
                    @if (!Model.Items.Any())
                    {
                        <div class="p-5 text-center">
                            <div class="mb-3 fs-1">🌸</div>
                            <p class="text-muted fw-medium">Bu siparişte ürün detayı bulunamadı.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <div class="product-entry p-4 d-flex align-items-center gap-4 transition-all border-bottom last-border-0">
                                <div class="position-relative">
                                    <img src="@item.ProductImage" alt="@item.ProductName" 
                                         style="width: 100px; height: 100px; object-fit: cover; border: 4px solid white;" 
                                         class="rounded-4 shadow-sm"
                                         onerror="this.src='https://images.unsplash.com/photo-1548094891-c4ba474eb5c1?w=400&q=80'">
                                    <span class="position-absolute bottom-0 end-0 badge rounded-pill bg-accent shadow-sm translate-middle-y translate-middle-x" style="margin-right: -10px; margin-bottom: -10px; padding: 6px 12px; font-size: 0.8rem;">x@item.Quantity</span>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold fs-5 mb-1" style="color: #3D2C33;">@item.ProductName</h6>
                                    @{
                                        decimal unitPrice = item.Quantity > 0 ? item.Price / item.Quantity : item.Price;
                                    }
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-muted fw-medium" style="font-size: 0.9rem;">Birim: @unitPrice.ToString("0.00") ₺</span>
                                        <span class="text-muted-soft">|</span>
                                        <span class="text-muted fw-medium" style="font-size: 0.9rem;">Toplam: @item.Price.ToString("0.00") ₺</span>
                                    </div>
                                </div>
                                <div class="text-end d-none d-sm-block">
                                    <div class="fw-extrabold fs-4 text-accent">@item.Price.ToString("0.00") ₺</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Info Panels -->
        <div class="col-lg-5">
            <div class="d-flex flex-column gap-4">
                <!-- Delivery Info -->
                <div class="card-soft border-0 bg-white p-4 shadow-sm">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="p-2 rounded-3 bg-soft-accent d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="fa-solid fa-location-dot text-accent fs-5"></i>
                        </div>
                        <h5 class="fw-extrabold mb-0" style="color: #3D2C33;">Teslimat Bilgileri</h5>
                    </div>
                    <div class="p-3 rounded-4" style="background-color: #F8F9FA;">
                        <h6 class="fw-bold mb-2 small text-uppercase text-muted" style="letter-spacing: 0.5px;">Teslimat Adresi</h6>
                        <p class="mb-0 text-dark fw-medium" style="line-height: 1.6;">@Model.ShippingAddress</p>
                    </div>
                </div>

                <!-- Payment Summary -->
                <div class="card-soft border-0 p-4 shadow-sm" style="background: linear-gradient(135deg, #3D2C33, #5c434d); color: white;">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-receipt opacity-75"></i> Ödeme Özeti
                    </h5>
                    
                    <div class="d-flex justify-content-between mb-3 opacity-75">
                        <span class="fw-medium">Ödeme Yöntemi</span>
                        <span class="fw-bold text-uppercase small">@(Model.CardLast4 == "BAKİYE" ? "Cüzdan Bakiyesi" : "Kart (**** " + Model.CardLast4 + ")")</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3 pt-3 border-top border-white border-opacity-10">
                        <span class="fw-medium opacity-75">Ara Toplam</span>
                        <span class="fw-bold">@Model.TotalAmount.ToString("0.00") ₺</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 opacity-75">
                        <span class="fw-medium">Kargo</span>
                        <span class="fw-bold">0,00 ₺</span>
                    </div>

                    <div class="rounded-4 p-4 d-flex justify-content-between align-items-center" style="background: rgba(255,255,255,0.07);">
                        <div>
                            <span class="d-block small text-uppercase opacity-50 fw-bold" style="letter-spacing: 1px;">Ödenen Toplam</span>
                            <span class="fs-2 fw-extrabold">@Model.TotalAmount.ToString("0.00") ₺</span>
                        </div>
                        <i class="fa-solid fa-circle-check fs-1 text-success opacity-75"></i>
                    </div>
                </div>

                <a asp-action="Orders" class="btn btn-outline-secondary w-100 rounded-pill py-3 fw-bold transition-all border-2">
                    <i class="fa-solid fa-arrow-left me-2"></i>Siparişlerime Dön
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f7f9fb; font-family: 'Quicksand', sans-serif; }
    .fw-extrabold { font-weight: 800; }
    .bg-soft-accent { background-color: rgba(212, 114, 138, 0.1); }
    .shadow-hover:hover { box-shadow: 0 15px 35px -10px rgba(0,0,0,0.1) !important; }
    .last-border-0:last-child { border-bottom: 0 !important; }
    .product-entry:hover { background-color: rgba(212, 114, 138, 0.02); }
    
    .pulse {
        animation: pulse-animation 2s infinite;
    }
    
    @@keyframes pulse-animation {
        0% { box-shadow: 0 0 0 0px rgba(212, 114, 138, 0.4); }
        100% { box-shadow: 0 0 0 15px rgba(212, 114, 138, 0); }
    }

    .step-circle {
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .step-circle:hover {
        transform: scale(1.1);
    }
    
    .text-muted-soft { color: #dee2e6; }
    .breadcrumb-item + .breadcrumb-item::before { content: "›"; color: #ADB5BD; font-weight: bold; }
</style>
