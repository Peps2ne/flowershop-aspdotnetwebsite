@{
    ViewData["Title"] = "İletişim";
}

<div class="inner-container">
    <div class="mb-5 text-center">
        <h2 class="fw-bold fs-1" style="color: #3D2C33;">Bizimle İletişime Geçin</h2>
        <p class="text-muted fw-semibold">Size yardımcı olmaktan mutluluk duyarız</p>
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="glass-panel p-5 h-100">
                <h4 class="fw-bold mb-4">Mesaj Gönderin</h4>
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Adınız Soyadınız</label>
                        <input type="text" class="form-control rounded-3 py-3" placeholder="Adınız">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">E-posta</label>
                        <input type="email" class="form-control rounded-3 py-3" placeholder="E-posta adresiniz">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Mesajınız</label>
                        <textarea class="form-control rounded-3 py-3" rows="5" placeholder="Size nasıl yardımcı olabiliriz?"></textarea>
                    </div>
                    <button type="button" class="btn btn-accent btn-lg w-100 rounded-pill mt-3">Mesajı Gönder</button>
                </form>
            </div>
        </div>
        
        <div class="col-md-5">
            <div class="glass-panel p-5 h-100 d-flex flex-column justify-content-center text-center">
                <div class="mb-5">
                    <div class="trust-icon mx-auto mb-3" style="width: 70px; height: 70px; font-size: 1.5rem;">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <h5 class="fw-bold">Mağazamız</h5>
                    <p class="text-muted fw-medium">Çiçek Sokak No:4, Botanik Mahallesi<br>İstanbul, TR</p>
                </div>
                
                <div class="mb-5">
                    <div class="trust-icon mx-auto mb-3" style="width: 70px; height: 70px; font-size: 1.5rem; background: #DCEEDC; color: #5C8C6C;">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <h5 class="fw-bold">Telefon</h5>
                    <p class="text-muted fw-medium">+90 (212) 555 01 23</p>
                </div>
                
                <div>
                    <div class="trust-icon mx-auto mb-3" style="width: 70px; height: 70px; font-size: 1.5rem; background: #FFD6C9; color: #C07060;">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <h5 class="fw-bold">E-posta</h5>
                    <p class="text-muted fw-medium">hello@bloomandco.com</p>
                </div>
            </div>
        </div>
    </div>
</div>
