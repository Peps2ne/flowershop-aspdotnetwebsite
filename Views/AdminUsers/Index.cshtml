@model IEnumerable<FlowerShopApp.Models.User>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert rounded-4 border-0 shadow-sm mb-4 fw-bold" style="background:#DCEEDC; color:#3D6C4C;">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Kullanıcı</th>
                    <th>E-Posta</th>
                    <th>Bakiye</th>
                    <th>Kayıt Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-muted small">@user.Id</td>
                        <td class="fw-bold">
                            <i class="fa-solid fa-user-circle text-accent me-2"></i>@user.Username
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2 fw-bold fs-6"
                                  style="background-color: #DCEEDC; color: #3D6C4C;">
                                @user.Balance.ToString("0.00") ₺
                            </span>
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-success rounded-pill px-3 me-1"
                                    data-bs-toggle="modal" data-bs-target="#balanceModal"
                                    data-userid="@user.Id" data-username="@user.Username">
                                <i class="fa-solid fa-plus"></i> Bakiye
                            </button>
                            <button class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2"
                                    data-bs-toggle="modal" data-bs-target="#removeBalanceModal"
                                    data-userid="@user.Id" data-username="@user.Username">
                                <i class="fa-solid fa-minus"></i> Düş
                            </button>
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline;"
                                  onsubmit="return confirm('@user.Username adlı kullanıcıyı silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Kayıtlı kullanıcı bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Balance Modal -->
<div class="modal fade" id="balanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color:#3D2C33;">Bakiye Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddBalance" method="post">
                <div class="modal-body px-4">
                    <p class="text-muted mb-3">Kullanıcı: <strong id="modalUsername"></strong></p>
                    <input type="hidden" name="id" id="modalUserId" />
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase text-muted mb-1">Eklenecek Tutar (₺)</label>
                        <input type="number" name="amount" step="0.01" min="1"
                               class="form-control rounded-pill p-3 fw-bold fs-5"
                               placeholder="100.00" required />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-accent rounded-pill px-5 fw-bold">
                        <i class="fa-solid fa-plus me-2"></i> Ekle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Remove Balance Modal -->
<div class="modal fade" id="removeBalanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color:#3D2C33;">Bakiye Düş</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RemoveBalance" method="post">
                <div class="modal-body px-4">
                    <p class="text-muted mb-3">Kullanıcı: <strong id="removeModalUsername"></strong></p>
                    <input type="hidden" name="id" id="removeModalUserId" />
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase text-muted mb-1">Düşülecek Tutar (₺)</label>
                        <input type="number" name="amount" step="0.01" min="1"
                               class="form-control rounded-pill p-3 fw-bold fs-5"
                               placeholder="100.00" required />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold">
                        <i class="fa-solid fa-minus me-2"></i> Düş
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var balanceModal = document.getElementById('balanceModal');
    balanceModal.addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        document.getElementById('modalUserId').value = btn.dataset.userid;
        document.getElementById('modalUsername').textContent = btn.dataset.username;
    });

    var removeBalanceModal = document.getElementById('removeBalanceModal');
    removeBalanceModal.addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        document.getElementById('removeModalUserId').value = btn.dataset.userid;
        document.getElementById('removeModalUsername').textContent = btn.dataset.username;
    });
</script>
}
