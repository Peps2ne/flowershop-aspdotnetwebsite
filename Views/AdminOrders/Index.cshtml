@model IEnumerable<FlowerShopApp.Models.Order>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sipariş Yönetimi";
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th>Sipariş No</th>
                    <th>Kullanıcı ID</th>
                    <th>Tarih</th>
                    <th>Toplam</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var statusText = order.Status switch
                    {
                        FlowerShopApp.Models.OrderStatus.Pending => "Hazırlanıyor",
                        FlowerShopApp.Models.OrderStatus.Shipped => "Yolda",
                        FlowerShopApp.Models.OrderStatus.Delivered => "Teslim Edildi",
                        _ => "İptal Edildi"
                    };
                    var statusBadge = order.Status switch
                    {
                        FlowerShopApp.Models.OrderStatus.Pending => "bg-warning text-dark",
                        FlowerShopApp.Models.OrderStatus.Shipped => "bg-info text-white",
                        FlowerShopApp.Models.OrderStatus.Delivered => "bg-success text-white",
                        _ => "bg-secondary text-white"
                    };
                    <tr>
                        <td class="fw-bold">#SPR-@order.Id</td>
                        <td class="text-muted small">@order.UserId</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="fw-bold text-accent">@order.TotalAmount.ToString("0.00") ₺</td>
                        <td><span class="badge @statusBadge rounded-pill px-3 py-2">@statusText</span></td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">Detay</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Henüz sipariş bulunmuyor.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
