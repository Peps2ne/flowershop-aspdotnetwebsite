@model IEnumerable<FlowerShopApp.Models.Discount>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "İndirim Kodu Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold m-0" style="color: #3D2C33;">Aktif Kodlar (@Model.Count(d => d.IsActive) / @Model.Count())</h5>
    <a asp-action="Create" class="btn btn-accent rounded-pill px-4 fw-bold">
        <i class="fa-solid fa-plus me-2"></i> Yeni Kod Ekle
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th>Kod</th>
                    <th>İndirim Oranı</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var discount in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-dark rounded-pill px-3 py-2 fs-6 text-white fw-bold">@discount.Code</span>
                        </td>
                        <td class="fw-bold text-accent fs-5">%@discount.DiscountPercentage</td>
                        <td>
                            @if (discount.IsActive)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3 py-2">Pasif</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="Toggle" asp-route-id="@discount.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm @(discount.IsActive ? "btn-outline-warning" : "btn-outline-success") rounded-pill px-3 me-2">
                                    @(discount.IsActive ? "Pasife Al" : "Aktif Et")
                                </button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@discount.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu kodu silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">Henüz indirim kodu eklenmemiş.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
